# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).

# ---- S3 data lake ----
S3_BUCKET_NAME=job-market-pipeline-raw
AWS_REGION=ap-south-1

# ---- Ingestion (Apify). Leave APIFY_API_TOKEN empty to use built-in mock data ----
APIFY_API_TOKEN=
APIFY_ACTOR_ID=bebity~linkedin-jobs-scraper
SEARCH_TERMS=Data Engineer,Junior Data Engineer,ETL Developer
LOCATIONS=India,Remote
MAX_RESULTS=100
FRESHNESS_DAYS=30

# ---- PostgreSQL serving layer ----
# Prefer DB_SECRET_ARN (Secrets Manager). The DB_* vars are for local runs only.
DB_SECRET_ARN=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobmarket
DB_USER=jobmarket
DB_PASSWORD=change-me
DQ_PASS_RATE_THRESHOLD=0.80

# ---- Observability ----
LOG_LEVEL=INFO
METRIC_NAMESPACE=JobMarketPipeline
INSIGHTS_SNS_TOPIC_ARN=
ALERT_SNS_TOPIC_ARN=
