# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/job_intelligence
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/job_intelligence

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_PRIMARY=gpt-4o-mini
AI_MODEL_SCORING=claude-sonnet-4-6

# ─── Job Sources ─────────────────────────────────────────────────────────────
JSEARCH_API_KEY=
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com
APIPY_API_TOKEN=
GREENHOUSE_API_KEY=
LEVER_API_KEY=

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=job-intelligence-resumes

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
